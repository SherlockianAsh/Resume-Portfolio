# Firebase Auth Configuration
# Get these from: Firebase Console → Project Settings → General → Your Apps → Web App
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Admin email whitelist (Google account used for sign-in)
VITE_ADMIN_EMAIL=

# JSONBin — resume data storage (public bin, no auth needed for read)
# Get bin ID from: jsonbin.io → Dashboard → your bin → ID in URL
VITE_JSONBIN_BIN_ID=
